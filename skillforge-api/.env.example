NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
# Full Neon connection string — omit to use local SQLite for development.
DATABASE_URL='postgresql://neondb_owner:YOUR_PASSWORD@ep-your-endpoint.region.aws.neon.tech/neondb?sslmode=require'

UPLOAD_DIR=uploads
CORS_ORIGINS=http://localhost:3000

# ── Physical Apprenticeship ML Services ──────────────────────────────────────
# Leave blank to skip — pipeline degrades gracefully.
# Claude vision is used as fallback for object detection when GROUNDING_DINO_URL is unset.

# Local Grounding DINO 1.5 inference server (open-vocab object detection)
# Expected endpoint: POST /predict  fields: image (file), prompt (str), threshold (float)
GROUNDING_DINO_URL=

# Local SAM 2 inference server (segmentation from bounding box prompt)
# Expected endpoint: POST /segment  fields: image (file), box (str "x1,y1,x2,y2" normalized)
SAM2_URL=

# SAM 3 inference server on NVIDIA Brev (concept segmentation from text or box prompt)
# Deploy deploy/sam3_server.py on a Brev GPU instance and expose port 8080.
# Expected endpoint: POST /segment  fields: image (file), text (str) or box (str "x1,y1,x2,y2")
SAM3_URL=

# Local DINOv2 inference server (visual feature extraction for object re-ID)
# Expected endpoint: POST /extract  fields: image (file)  returns: {"features": [...]}
DINOV2_URL=
