NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CORS_ORIGINS=http://localhost:3000



# ── ASR (Automatic Speech Recognition) ──────────────────────────────────────
# Self-hosted NVIDIA NIM Parakeet CTC 1.1B on Brev GPU.
# Point this at your Brev instance's NIM transcription endpoint.
# Leave blank to use the NVIDIA NIM cloud API (requires NVIDIA_NIM_API_KEY).
ASR_URL=http://localhost:8091/transcribe

# ── Database (Neon PostgreSQL) — required ─────────────────────────────────────
DATABASE_URL='postgresql://neondb_owner:YOUR_PASSWORD@ep-your-endpoint.region.aws.neon.tech/neondb?sslmode=require'

UPLOAD_DIR=uploads
CORS_ORIGINS=http://localhost:3000


# SAM 3 inference server on NVIDIA Brev (concept segmentation from text or box prompt)
# Deploy deploy/sam3_server.py on a Brev GPU instance and expose port 8080.
# Expected endpoint: POST /segment  fields: image (file), text (str) or box (str "x1,y1,x2,y2")
SAM3_URL=http://localhost:8090

# ── Nemotron VLM (Vision-Language frame analysis) ─────────────────────────────
# Self-hosted Nemotron Nano 12B VL on Brev GPU (OpenAI-compatible /v1/chat/completions).
# Port-forward: brev port-forward sam3-server -p 8092:8082
# No API key required — server has no auth, model is public on HuggingFace.
NEMOTRON_URL=http://localhost:8092
